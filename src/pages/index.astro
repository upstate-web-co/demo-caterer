---
import Layout from '../layouts/Layout.astro'
import { SITE, MENUS, EVENT_TYPES, TESTIMONIALS } from '../lib/config'
---

<Layout>
  <!-- Hero -->
  <section class="relative h-[70vh] flex items-center justify-center overflow-hidden">
    <img src="https://images.unsplash.com/photo-1555244162-803834f70033?w=1200&q=75&auto=format" alt="Catering spread" class="absolute inset-0 w-full h-full object-cover brightness-[0.35]" loading="eager" width="1200" height="800" fetchpriority="high" />
    <div class="relative text-center px-6">
      <p class="text-copper-light text-sm uppercase tracking-[0.25em] mb-4" style="font-family: system-ui, sans-serif;">Full-Service Catering · Greenville, SC</p>
      <h1 class="text-5xl md:text-7xl text-white tracking-tight">Copper Elm</h1>
      <p class="mt-4 text-xl text-white/80 italic">{SITE.tagline}</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center" style="font-family: system-ui, sans-serif;">
        <a href="#inquiry" class="rounded-lg bg-copper px-8 py-3 font-medium text-white hover:bg-copper-dark transition-colors">Get a Quote</a>
        <a href="#menus" class="rounded-lg border border-white/30 px-8 py-3 font-medium text-white hover:bg-white/10 transition-colors">Browse Menus</a>
      </div>
    </div>
  </section>

  <!-- Inline AI -->
  <section class="bg-warm py-6 px-6">
    <div class="mx-auto max-w-xl">
      <div class="flex gap-2">
        <input id="ai-ask" type="text" placeholder="Can you do a BBQ for 100? What about gluten-free options? How far in advance should I book?" class="flex-1 rounded-lg border border-copper/20 bg-white px-5 py-3 text-sm placeholder:text-muted focus:border-copper focus:outline-none" />
        <button id="ai-send" class="rounded-lg bg-copper px-5 py-3 text-sm font-medium text-white hover:bg-copper-dark transition-colors" style="font-family: system-ui, sans-serif;">Ask</button>
      </div>
      <div id="ai-response" class="hidden mt-3 rounded-xl bg-white border border-copper/10 p-4 text-sm leading-relaxed"></div>
    </div>
  </section>

  <!-- Menus -->
  <section id="menus" class="py-20 px-6">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-3xl text-center mb-2">Our Menus</h2>
      <p class="text-center text-muted text-sm mb-10">Every menu is customizable. These are starting points — we build around your vision, venue, and budget.</p>
      <div class="grid md:grid-cols-2 gap-5">
        {MENUS.map((menu) => (
          <div class="rounded-xl border border-copper/10 bg-white p-6">
            <div class="flex items-start justify-between mb-2">
              <h3 class="text-lg font-medium">{menu.name}</h3>
              <span class="text-xs bg-copper/10 text-copper px-2 py-1 rounded-full" style="font-family: system-ui, sans-serif;">{menu.type}</span>
            </div>
            <p class="text-copper font-medium" style="font-family: system-ui, sans-serif;">{menu.price}</p>
            <p class="text-sm text-muted mt-2 leading-relaxed">{menu.description}</p>
            <button data-add-item data-name={menu.name} data-price={menu.price.replace(/[^0-9]/g, '')} data-label="Add to Quote" class="mt-3 rounded-lg bg-copper/10 text-copper text-xs font-medium px-3 py-1.5 hover:bg-copper/20 transition-colors" style="font-family: system-ui, sans-serif;">Add to Quote</button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="py-20 px-6 bg-warm">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-3xl text-center mb-10">From Our Kitchen</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80" alt="Plated dinner" class="rounded-xl aspect-square object-cover" loading="lazy" />
        <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=600&q=80" alt="Appetizers" class="rounded-xl aspect-square object-cover" loading="lazy" />
        <img src="https://images.unsplash.com/photo-1467003909585-2f8a72700288?w=600&q=80" alt="BBQ spread" class="rounded-xl aspect-square object-cover" loading="lazy" />
        <img src="https://images.unsplash.com/photo-1476224203421-9ac39bcb3327?w=600&q=80" alt="Catering setup" class="rounded-xl aspect-square object-cover" loading="lazy" />
        <img src="https://images.unsplash.com/photo-1529692236671-f1f6cf9683ba?w=600&q=80" alt="Dessert display" class="rounded-xl aspect-square object-cover" loading="lazy" />
        <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?w=600&q=80" alt="Farm to table" class="rounded-xl aspect-square object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="py-20 px-6">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-3xl text-center mb-10">What Our Clients Say</h2>
      <div class="grid md:grid-cols-3 gap-5">
        {TESTIMONIALS.map((t) => (
          <div class="rounded-xl border border-copper/10 bg-white p-6">
            <p class="text-sm italic leading-relaxed">"{t.quote}"</p>
            <div class="mt-4 pt-3 border-t border-copper/10">
              <p class="text-sm font-medium">{t.author}</p>
              <p class="text-xs text-muted">{t.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section id="inquiry" class="py-20 px-6 bg-warm">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-3xl text-center mb-2">Tell Us About Your Event</h2>
      <p class="text-center text-muted text-sm mb-10">The more detail you share, the better we can quote. We respond within 24 hours.</p>
      <form id="inquiry-form" class="space-y-4 bg-white rounded-xl border border-copper/10 p-6">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Your Name</label>
            <input type="text" name="name" required class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Email</label>
            <input type="email" name="email" required class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none" />
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Event Date</label>
            <input type="date" name="date" required class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Guest Count</label>
            <select name="guests" required class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none">
              <option value="">Select...</option>
              <option value="20-50">20–50</option>
              <option value="50-100">50–100</option>
              <option value="100-200">100–200</option>
              <option value="200+">200+</option>
            </select>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Event Type</label>
            <select name="event_type" required class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none">
              <option value="">Select...</option>
              {EVENT_TYPES.map(t => <option value={t.toLowerCase()}>{t}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Budget Range</label>
            <select name="budget" class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none">
              <option value="">Approximate...</option>
              <option value="under-2k">Under $2,000</option>
              <option value="2k-5k">$2,000–$5,000</option>
              <option value="5k-10k">$5,000–$10,000</option>
              <option value="10k+">$10,000+</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Venue</label>
          <input type="text" name="venue" placeholder="Venue name and city" class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm text-charcoal mb-1" style="font-family: system-ui, sans-serif;">Tell us about your vision</label>
          <textarea name="details" rows="4" placeholder="Menu preferences, dietary needs, service style, anything special..." class="w-full rounded-lg border border-copper/20 px-4 py-2.5 text-sm bg-linen focus:border-copper focus:outline-none"></textarea>
        </div>
        <button type="submit" class="w-full rounded-lg bg-copper px-6 py-3 font-medium text-white hover:bg-copper-dark transition-colors" style="font-family: system-ui, sans-serif;">Request a Quote</button>
        <div id="form-status" class="hidden rounded-lg p-3 text-center text-sm"></div>
      </form>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-add-item]').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const name = el.dataset.name!;
        const price = el.dataset.price!;
        (window as any).addToCart(name, price);
        el.textContent = 'Added!';
        setTimeout(() => { el.textContent = el.dataset.label || 'Add to Quote'; }, 1000);
      });
    });
  </script>

  <script>
    document.getElementById('inquiry-form')?.addEventListener('submit', (e) => {
      e.preventDefault()
      const status = document.getElementById('form-status')!
      status.textContent = 'Thank you! We\'ll get back to you within 24 hours with menu options and a custom quote.'
      status.className = 'rounded-lg bg-copper/10 border border-copper/20 p-3 text-center text-sm text-copper-dark'
      ;(e.target as HTMLFormElement).querySelectorAll('input, select, textarea, button').forEach(el => (el as HTMLInputElement).disabled = true)
    })

    const aiInput = document.getElementById('ai-ask') as HTMLInputElement
    const aiSend = document.getElementById('ai-send')!
    const aiResponse = document.getElementById('ai-response')!
    async function askAI() {
      const text = aiInput.value.trim()
      if (!text) return
      aiResponse.textContent = 'Checking...'
      aiResponse.classList.remove('hidden')
      try {
        const res = await fetch('/api/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: text }) })
        const data = await res.json()
        aiResponse.textContent = data.reply || 'Not sure — fill out the inquiry form and we\'ll help!'
      } catch { aiResponse.textContent = 'Something went wrong. Email us at events@copperelmcatering.com!' }
    }
    aiSend.addEventListener('click', askAI)
    aiInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') askAI() })
  </script>
</Layout>
